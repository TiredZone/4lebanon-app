#!/usr/bin/env sh

# Run type checking and tests before pushing
# This prevents broken code from being pushed to the repository

echo "🔍 Running pre-push checks..."

# Type checking
echo "📝 Running TypeScript type check..."
npm run typecheck
if [ $? -ne 0 ]; then
  echo "❌ TypeScript type check failed. Please fix the errors before pushing."
  exit 1
fi

echo "✅ All pre-push checks passed!"
