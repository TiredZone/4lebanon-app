# ==============================================
# 4Lebanon — Environment Variables
# ==============================================
# Copy this file to .env.local and fill in the values.
# See lib/env.ts for validation rules.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, never exposed to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://4lebanon.com

# --- Revalidation ---
# Webhook secret for on-demand ISR revalidation (min 16 chars)
REVALIDATE_SECRET=change-me-to-a-long-random-string

# --- Node ---
NODE_ENV=development
